// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  PLATFORM_ADMIN
  USER
}

enum OrgRole {
  ORG_ADMIN
  MANAGER
  MENTOR
  LEARNER
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String
  role          PlatformRole   @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  profile       LearnerProfile?
  enrollments   CourseEnrollment[]
  quizAttempts  QuizAttempt[]
  studySessions StudySession[]
  memberships   OrganizationMembership[]
  refreshTokens RefreshToken[]
  payments      Payment[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     OrganizationMembership[]
  courses     Course[]
}

model OrganizationMembership {
  id             String       @id @default(uuid())
  organizationId String
  userId         String
  role           OrgRole      @default(LEARNER)
  organization   Organization @relation(fields: [organizationId], references: [id])
  user           User         @relation(fields: [userId], references: [id])
  createdAt      DateTime     @default(now())

  @@unique([organizationId, userId])
}

model LearnerProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  bio       String?
  interests String?
  goals     String?
  createdAt DateTime @default(now())
}

model Course {
  id             String   @id @default(uuid())
  title          String
  description    String?
  imageUrl       String?
  difficulty     String   @default("Beginner")
  visibility     String   @default("Private Draft")
  price          Float    @default(0)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  modules        Module[]
  enrollments    CourseEnrollment[]
  payments       Payment[]
}

model Module {
  id       String  @id @default(uuid())
  title    String
  order    Int
  courseId String
  course   Course  @relation(fields: [courseId], references: [id])
  topics   Topic[]
}

model Topic {
  id       String  @id @default(uuid())
  title    String
  order    Int
  moduleId String
  module   Module  @relation(fields: [moduleId], references: [id])
  
  materials     Material[]
  contentChunks ContentChunk[]
  questions     Question[]
  progress      TopicProgress[]
}

model Material {
  id        String @id @default(uuid())
  filename  String
  filePath  String
  mimeType  String
  version   Int    @default(1)
  topicId   String
  topic     Topic  @relation(fields: [topicId], references: [id])
}

model ContentChunk {
  id      String @id @default(uuid())
  content String
  order   Int
  topicId String
  topic   Topic  @relation(fields: [topicId], references: [id])
}

model CourseEnrollment {
  id         String   @id @default(uuid())
  userId     String
  courseId   String
  enrolledAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  course     Course   @relation(fields: [courseId], references: [id])
  
  topicProgress TopicProgress[]
  @@unique([userId, courseId])
}

model TopicProgress {
  id           String   @id @default(uuid())
  enrollmentId String
  topicId      String
  status       String   @default("locked") // locked, unlocked, in_progress, completed
  enrollment   CourseEnrollment @relation(fields: [enrollmentId], references: [id])
  topic        Topic    @relation(fields: [topicId], references: [id])
  @@unique([enrollmentId, topicId])
}

model StudySession {
  id        String   @id @default(uuid())
  userId    String
  topicId   String
  startedAt DateTime @default(now())
  endedAt   DateTime?
  duration  Int?     // seconds
  user      User     @relation(fields: [userId], references: [id])
}

model Question {
  id       String @id @default(uuid())
  text     String
  topicId  String
  topic    Topic  @relation(fields: [topicId], references: [id])
  options  QuestionOption[]
}

model QuestionOption {
  id         String  @id @default(uuid())
  text       String
  isCorrect  Boolean
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
}

model QuizAttempt {
  id        String   @id @default(uuid())
  userId    String
  topicId   String
  score     Float?
  passed    Boolean?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  answers   LearnerAnswer[]
}

model LearnerAnswer {
  id            String      @id @default(uuid())
  attemptId     String
  questionId    String
  selectedOption String
  isCorrect     Boolean
  attempt       QuizAttempt @relation(fields: [attemptId], references: [id])
}

model Payment {
  id              String   @id @default(uuid())
  userId          String
  courseId        String
  amount          Float
  currency        String   @default("INR")
  status          String   @default("pending") // pending, completed, failed
  provider        String   // razorpay, stripe
  providerOrderId String   @unique
  providerPaymentId String? @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
  course          Course   @relation(fields: [courseId], references: [id])
}
